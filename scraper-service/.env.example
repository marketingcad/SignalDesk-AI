# ─── Backend API ───
BACKEND_API_URL=http://localhost:3000
BACKEND_AUTH_TOKEN=your_jwt_token_here

# ─── Discord Alerts ───
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ─── Scraper Service ───
PORT=4000

# ─── Scheduler (cron expressions) ───
# Staggered to avoid concurrent scrapes and rate limits.
# Reddit: every hour (public, lenient)
# X: every 2 hours (Google dorks)
# LinkedIn: every 6 hours (Google dorks, stricter)
# Facebook: every 2 hours (needs login)
CRON_REDDIT=0 */1 * * *
CRON_X=30 */2 * * *
CRON_LINKEDIN=15 */6 * * *
CRON_FACEBOOK=45 */2 * * *

# ─── Scraper Targets ───
# Reddit: business owner subreddits (not VA communities where VAs post)
REDDIT_SUBREDDITS=entrepreneur,smallbusiness,ecommerce,startups,SaaS,realestateinvesting,dropship,FulfillmentByAmazon,hiring,forhire,virtualassistant,RemoteWork,Bookkeeping,socialmediamarketing,RealEstate,DigitalMarketing

# Search queries used for Google dorks (site:x.com, site:linkedin.com/posts)
# These are fallbacks — Settings page keywords take priority when configured.
X_SEARCH_QUERIES=hiring virtual assistant,need a VA,looking for VA,hire a va,va needed,hiring remote assistant,hiring executive assistant remote,hiring ghl va,hiring social media va,hiring real estate va,hiring cold caller va,hiring appointment setter,need admin support,need someone to manage my crm,any va recommendations,recommend a good va,overwhelmed with admin,scaling my business and need help,hiring bookkeeping va
LINKEDIN_SEARCH_QUERIES=hiring virtual assistant,need VA for business,looking for a virtual assistant,hire a virtual assistant,virtual assistant needed,hiring remote assistant,hiring executive assistant remote,need admin support,outsourcing admin work,where to find a va,thinking of hiring a va,need someone to manage my crm,overwhelmed with admin,hiring appointment setter
FACEBOOK_SEARCH_QUERIES=hiring virtual assistant,need a VA,looking for virtual assistant,hire VA for business,hiring remote assistant,need admin support,hiring appointment setter,hiring social media va,looking for a va,overwhelmed need help,hiring ghl va,need someone to manage my crm

# Facebook group URLs (direct scraping — best for private groups with login)
# Add your target Facebook group URLs here, comma-separated.
# Example: https://www.facebook.com/groups/123456/,https://www.facebook.com/groups/789012/
FACEBOOK_GROUP_URLS=

# ─── Rate Limits ───
MAX_RESULTS_PER_RUN=50
SCROLL_DELAY_MS=2000
REQUEST_TIMEOUT_MS=30000

# ─── Browser ───
HEADLESS=true

# ─── Supabase (optional — enables durable persistence for schedules) ───
# If not set, schedules are stored in local JSON files.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Retry & Resilience ───
SCRAPE_RETRY_ATTEMPTS=1
SCRAPE_RETRY_DELAY_MS=30000

# ─── Keyword Cache TTL (ms) ───
KEYWORD_CACHE_TTL_MS=300000

# ─── Per-Platform Rate Limits (ms between scrapes) ───
RATE_LIMIT_FACEBOOK_MS=300000
RATE_LIMIT_LINKEDIN_MS=300000
RATE_LIMIT_REDDIT_MS=60000
RATE_LIMIT_X_MS=60000
RATE_LIMIT_OTHER_MS=10000

# ─── Min Post Length per Platform (chars) ───
MIN_POST_LENGTH_FACEBOOK=20
MIN_POST_LENGTH_LINKEDIN=20
MIN_POST_LENGTH_REDDIT=20
MIN_POST_LENGTH_X=10
MIN_POST_LENGTH_OTHER=20

# ─── Session Health Alert Threshold ───
SESSION_HEALTH_THRESHOLD=3
